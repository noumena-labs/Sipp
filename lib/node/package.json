{
  "name": "@noumena-labs/sipp-server",
  "version": "0.1.0",
  "description": "Native Node.js server bindings for Sipp",
  "main": "router.js",
  "types": "router.d.ts",
  "exports": {
    ".": {
      "types": "./router.d.ts",
      "require": "./router.js",
      "default": "./router.js"
    }
  },
  "license": "Apache-2.0",
  "files": [
    "index.d.ts",
    "gateway-profile.js",
    "LICENSE",
    "README.md",
    "THIRD_PARTY_NOTICES.md",
    "router.d.ts",
    "router.js"
  ],
  "scripts": {
    "build": "cargo xtask build node --backend all",
    "build:stage": "node scripts/stage-package.mjs",
    "test": "node --test tests/router.test.mjs"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/noumena-labs/Sipp.git",
    "directory": "lib/node"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "restricted"
  },
  "napi": {
    "binaryName": "sipp_node",
    "targets": [
      "x86_64-apple-darwin",
      "aarch64-apple-darwin",
      "x86_64-pc-windows-msvc",
      "x86_64-unknown-linux-gnu"
    ]
  },
  "devDependencies": {
    "@napi-rs/cli": "^3.3.0",
    "c8": "^10.1.3"
  }
}
