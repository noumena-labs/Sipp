{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Attach backend-ops WebGPU Debug",
      "type": "pwa-chrome",
      "request": "attach",
      "address": "127.0.0.1",
      "port": 9222,
      "urlFilter": "http://127.0.0.1:*/__runner__/runner.html*",
      "webRoot": "${workspaceFolder}/packages/cogent-engine",
      "enableDWARF": true,
      "trace": true,
      "sourceMapPathOverrides": {
        "../../third_party/*": "${workspaceFolder}/packages/cogent-engine/third_party/*",
        "../../src/*": "${workspaceFolder}/packages/cogent-engine/src/*",
        "../../native/*": "${workspaceFolder}/packages/cogent-engine/native/*",
        "../../scripts/*": "${workspaceFolder}/packages/cogent-engine/scripts/*",
        "/third_party/*": "${workspaceFolder}/packages/cogent-engine/third_party/*",
        "/src/*": "${workspaceFolder}/packages/cogent-engine/src/*",
        "/native/*": "${workspaceFolder}/packages/cogent-engine/native/*",
        "/scripts/*": "${workspaceFolder}/packages/cogent-engine/scripts/*"
      },
      "preLaunchTask": "backend-ops:webgpu:debug"
    },
    {
      "name": "Attach backend-ops WebGPU Debug (Custom)",
      "type": "pwa-chrome",
      "request": "attach",
      "address": "127.0.0.1",
      "port": 9222,
      "urlFilter": "http://127.0.0.1:*/__runner__/runner.html*",
      "webRoot": "${workspaceFolder}/packages/cogent-engine",
      "enableDWARF": true,
      "trace": true,
      "sourceMapPathOverrides": {
        "../../third_party/*": "${workspaceFolder}/packages/cogent-engine/third_party/*",
        "../../src/*": "${workspaceFolder}/packages/cogent-engine/src/*",
        "../../native/*": "${workspaceFolder}/packages/cogent-engine/native/*",
        "../../scripts/*": "${workspaceFolder}/packages/cogent-engine/scripts/*",
        "/third_party/*": "${workspaceFolder}/packages/cogent-engine/third_party/*",
        "/src/*": "${workspaceFolder}/packages/cogent-engine/src/*",
        "/native/*": "${workspaceFolder}/packages/cogent-engine/native/*",
        "/scripts/*": "${workspaceFolder}/packages/cogent-engine/scripts/*"
      },
      "preLaunchTask": "backend-ops:webgpu:debug:custom"
    },
    {
      "name": "Attach existing backend-ops WebGPU Debug",
      "type": "pwa-chrome",
      "request": "attach",
      "address": "127.0.0.1",
      "port": 9222,
      "urlFilter": "http://127.0.0.1:*/__runner__/runner.html*",
