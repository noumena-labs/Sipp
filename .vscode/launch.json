      "enableDWARF": true,
      "trace": true,
      "sourceMapPathOverrides": {
        "../../third_party/*": "${workspaceFolder}/packages/cogent-engine/third_party/*",
        "../../src/*": "${workspaceFolder}/packages/cogent-engine/src/*",
        "../../native/*": "${workspaceFolder}/packages/cogent-engine/native/*",
        "../../scripts/*": "${workspaceFolder}/packages/cogent-engine/scripts/*",
        "/third_party/*": "${workspaceFolder}/packages/cogent-engine/third_party/*",
        "/src/*": "${workspaceFolder}/packages/cogent-engine/src/*",
        "/native/*": "${workspaceFolder}/packages/cogent-engine/native/*",
        "/scripts/*": "${workspaceFolder}/packages/cogent-engine/scripts/*"
      }
    }
  ]
}
