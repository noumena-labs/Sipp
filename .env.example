# Provider smoke-test configuration.
# Copy this file to .env in this directory and replace the placeholder key.
#
# Run from the workspace root:
#   cargo run -p sipp-providers --example provider_smoke

# Provider preset:
#   openai | anthropic | gemini | deepseek | qwen | kimi | glm | proxy
SIPP_PROVIDER=gemini

# Provider model id. Examples:
#   gemini:   gemini-2.5-flash
#   openai:   gpt-4.1-mini
#   anthropic: claude-sonnet-4-20250514
#   deepseek: deepseek-chat
#   qwen:     qwen-max
#   kimi:     kimi-k2-0711-preview
#   glm:      glm-4.5
SIPP_MODEL=gemini-2.5-flash

# Optional prompt and runtime behavior.
SIPP_PROMPT=Say hi in one sentence.
SIPP_STREAM=false
SIPP_LIST_MODELS=false
SIPP_TIMEOUT_MS=60000

# Optional generic overrides.
# SIPP_API_KEY overrides provider-specific key variables below.
# SIPP_API_KEY=
# SIPP_API_KEY_ENV=MY_CUSTOM_PROVIDER_KEY
# SIPP_BASE_URL=https://your-openai-compatible-prefix/v1
# SIPP_ANTHROPIC_VERSION=2023-06-01

# Provider-specific API keys. Set the one matching SIPP_PROVIDER.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
DEEPSEEK_API_KEY=
DASHSCOPE_API_KEY=
MOONSHOT_API_KEY=
ZAI_API_KEY=
PROVIDER_API_KEY=
