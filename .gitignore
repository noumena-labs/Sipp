# =========================
# Core OS, Environment & Logs
# =========================
.DS_Store
*.log
logs/
log/
output_debug.log
.env
.env.local
.env.*.local
/.build/

# =========================
# Rust / Cargo
# =========================
# With a root Cargo workspace, all Rust builds funnel into this single directory
/target/
**/*.rs.bk

# =========================
# Node / Bun
# =========================
node_modules/
# Note: Do not ignore bun.lock or Cargo.lock, they should be checked into version control
npm-debug.log*
yarn-error.log*

# =========================
# JS/TS Apps & Packages
# =========================
dist/
build/
/apps/*/dist/
/apps/*/build/
/apps/*/.next/
/apps/*/.svelte-kit/
/lib/node/dist/
/lib/node/build/
/lib/web/dist/
/lib/web/build/
/lib/web/src/wasm/cogentlm-wasm*.js
/lib/web/src/wasm/cogentlm-wasm*.wasm

# =========================
# Bindings & Cross-Compilation
# =========================
# Python
.venv/
__pycache__/
.pytest_cache/
*.py[cod]
*$py.class
*.whl

# Node NAPI (.node binary files)
*.node

# WASM build artifacts (if wasm-pack generates a local pkg folder)
/bindings/wasm/pkg/

# =========================
# C++ / CMake (llama.cpp)
# =========================
CMakeCache.txt
CMakeFiles/
cmake_install.cmake
/third_party/llama.cpp/build/
*.o
*.a
*.so
*.dylib

# IDE & Autocomplete databases (Generated by build.rs)
compile_commands.json
compile_flags.txt
.clangd/
.cache/clangd/


# =========================
# Machine Learning Models
# =========================
*.gguf
*.bin

# =========================
# Toolchains & Bootstraps
# =========================
third_party/emsdk/
third_party/ninja/
/.toolchain/
.run_emsdk_wrapper.*

# =========================
# Turborepo
# =========================
.turbo/

# =========================
# Legacy Cruft (Safe to keep until fully cleaned)
# =========================
build-check/
build-probe/
build-probe2/
build-*/
a.out.js
a.out.wasm
target-wasm*/


# =========================
