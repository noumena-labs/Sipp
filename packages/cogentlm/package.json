{
  "name": "@noumena-labs/cogentlm",
  "version": "0.0.1",
  "description": "Browser-focused inference runtime for llama.cpp compiled to WebAssembly.",
  "main": "dist/esm/index.js",
  "types": "dist/types/index.d.ts",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/esm/index.js",
      "default": "./dist/esm/index.js"
    },
    "./character": {
      "types": "./dist/types/character/index.d.ts",
      "import": "./dist/esm/character/index.js",
      "default": "./dist/esm/character/index.js"
    },
    "./character/advanced": {
      "types": "./dist/types/character/advanced.d.ts",
      "import": "./dist/esm/character/advanced.js",
      "default": "./dist/esm/character/advanced.js"
    },
    "./director": {
      "types": "./dist/types/director/index.d.ts",
      "import": "./dist/esm/director/index.js",
      "default": "./dist/esm/director/index.js"
    },
    "./wasm/*": "./dist/wasm/*",
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "clean": "bun ./scripts/clean.mjs",
    "build": "bun run build:wasm && bun run build:ts",
    "build:release": "bun run clean && bun run build:wasm && bun run build:ts",
    "build:dev": "bun run build:wasm:dev && bun run build:ts",
    "rebuild": "bun run clean && bun run build",
    "build:wasm": "bun ./scripts/build-wasm.mjs",
    "build:wasm:dev": "bun ./scripts/build-wasm-dev.mjs",
    "release:prepare": "bun run build:release && bun run pack:validate",
    "test:backend-ops:webgpu": "bun ./scripts/test-backend-ops-webgpu.mjs",
    "test:backend-ops:webgpu:op": "bun ./scripts/test-backend-ops-webgpu-op.mjs",
    "test:backend-ops:webgpu:debug": "bun ./scripts/test-backend-ops-webgpu-op.mjs --debug",
    "test:backend-ops:cuda": "bun ./scripts/test-backend-ops-cuda.mjs",
    "test:backend-ops:cuda:op": "bun ./scripts/test-backend-ops-cuda-op.mjs",
    "test:backend-ops:cuda:debug": "bun ./scripts/test-backend-ops-cuda-op.mjs --debug",
    "build:ts": "bun ./scripts/clean-ts-dist.mjs && bun ./scripts/build-ts.mjs",
    "pack:validate": "bun ./scripts/validate-pack.mjs"
  },
  "keywords": [
    "llm",
    "cogent",
    "inference",
    "webgpu"
  ],
  "author": "noumena-labs",
  "homepage": "https://www.cogentlm.com/",
  "bugs": {
    "url": "https://github.com/noumena-labs/CogentLM/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/noumena-labs/CogentLM.git",
    "directory": "packages/cogentlm"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "restricted"
  },
  "license": "Apache-2.0",
  "devDependencies": {
    "typescript": "^5.3.3",
    "@types/node": "^20.10.0",
    "playwright": "^1.56.1"
  }
}
