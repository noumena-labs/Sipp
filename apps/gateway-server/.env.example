# Copy this file to a private env file and replace the placeholder secrets.
COGENTLM_GATEWAY_IMAGE=cogentlm-gateway:vulkan
COGENTLM_GATEWAY_BACKEND=vulkan
COGENTLM_GATEWAY_BUILDER_IMAGE=rust:bookworm
COGENTLM_GATEWAY_RUNTIME_IMAGE=debian:bookworm-slim
COGENTLM_GATEWAY_INSTALL_RUSTUP=0
COGENTLM_GATEWAY_RUNTIME_ENV_FILE=./.env
COGENTLM_GATEWAY_TOKEN=replace-me
COGENTLM_MODEL_DIR=../../.build/models
COGENTLM_GATEWAY_CONFIG=./config/development.toml
COGENTLM_GATEWAY_PUBLIC_PORT=8080
COGENTLM_GATEWAY_MANAGEMENT_PORT=9090
RUST_LOG=info
