name: cogentlm-gateway-development

services:
  gateway:
    image: cogentlm-gateway:vulkan
    build:
      context: ../..
      dockerfile: apps/gateway-server/Dockerfile
      args:
        COGENTLM_GATEWAY_BACKEND: vulkan
        COGENTLM_GATEWAY_BUILDER_IMAGE: rust:bookworm
        COGENTLM_GATEWAY_RUNTIME_IMAGE: debian:bookworm-slim
        COGENTLM_GATEWAY_INSTALL_RUSTUP: "0"
    env_file:
      - path: ./.env
        required: true
    working_dir: /workspace
    volumes:
      - type: bind
        source: ./config/development.toml
        target: /etc/cogentlm/gateway.toml
        read_only: true
      - type: bind
        source: ../../.build/models
        target: /models
        read_only: true
    ports:
      - "127.0.0.1:8080:8080"
      - "127.0.0.1:9090:9090"
    stop_grace_period: 30s
    healthcheck:
      test: ["CMD", "curl", "--fail", "--silent", "http://127.0.0.1:9090/readyz"]
      interval: 10s
      timeout: 3s
      retries: 6
      start_period: 30s
    read_only: true
    tmpfs:
      - /tmp
    security_opt:
      - no-new-privileges:true
