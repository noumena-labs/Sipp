name: sipp-gateway-provider-development

services:
  gateway:
    image: sipp-gateway:provider-cpu
    build:
      context: ../..
      dockerfile: apps/gateway-server/Dockerfile
      args:
        SIPP_GATEWAY_BACKEND: cpu
        SIPP_GATEWAY_BUILDER_IMAGE: rust:bookworm
        SIPP_GATEWAY_RUNTIME_IMAGE: debian:bookworm-slim
        SIPP_GATEWAY_INSTALL_RUSTUP: "0"
    env_file:
      - path: ./.env
        required: true
    working_dir: /workspace
    volumes:
      - type: bind
        source: ./config/provider-only.toml
        target: /etc/sipp/gateway.toml
        read_only: true
    ports:
      - "127.0.0.1:8080:8080"
      - "127.0.0.1:9090:9090"
    stop_grace_period: 30s
    healthcheck:
      test: ["CMD", "curl", "--fail", "--silent", "http://127.0.0.1:9090/readyz"]
      interval: 10s
      timeout: 3s
      retries: 6
      start_period: 30s
    read_only: true
    tmpfs:
      - /tmp
    security_opt:
      - no-new-privileges:true
