{
  "compilerOptions": {
    "target": "ESNext",
    "useDefineForClassFields": true,
    "module": "ESNext",
    "lib": ["ESNext", "DOM", "DOM.Iterable"],
    "skipLibCheck": true,

    /* Bundler mode */
    "baseUrl": ".",
    "paths": {
      "@noumena-labs/cogentlm": [
        "../../.build/artifacts/npm/cogentlm/dist/types/index.d.ts"
      ],
      "@noumena-labs/cogentlm/character": [
        "../../.build/artifacts/npm/cogentlm/dist/types/character/index.d.ts"
      ],
      "@noumena-labs/cogentlm/director": [
        "../../.build/artifacts/npm/cogentlm/dist/types/orchestrator/index.d.ts"
      ]
    },
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,

    /* Linting */
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true
  },
  "include": ["src"]
}
