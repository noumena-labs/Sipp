{
    "$schema": "https://turbo.build/schema.json",
    "tasks": {
        "build": {
            "dependsOn": [
                "^build"
            ],
            "outputs": [
                "../../.build/artifacts/**"
            ],
            "inputs": [
                "src/**",
                "package.json",
                "tsconfig.json",
                "../../crates/**",
                "../../lib/**",
                "../../bindings/**",
                "../../xtask/**"
            ]
        },
        "dev": {
            "cache": false,
            "persistent": true
        },
        "test": {
            "dependsOn": [
                "build"
            ]
        },
        "clean": {
            "cache": false
        }
    }
}
