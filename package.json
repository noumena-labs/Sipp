{
  "name": "cogent-engine-monorepo",
  "private": true,
  "version": "1.0.0",
  "packageManager": "bun@1.3.11",
  "workspaces": [
    "packages/*",
    "apps/benchmark",
    "apps/avatar",
    "apps/simulation"
  ],
  "scripts": {
    "build": "bun run build:package",
    "build:package": "bun run --filter=@noumena-labs/cogent-engine build",
    "build:package:release": "bun run --filter=@noumena-labs/cogent-engine build:release",
    "build:package:dev": "bun run --filter=@noumena-labs/cogent-engine build:dev",
    "rebuild:package": "bun run --filter=@noumena-labs/cogent-engine rebuild",
    "clean:package": "bun run --filter=@noumena-labs/cogent-engine clean",
    "test:backend-ops:webgpu": "bun run --filter=@noumena-labs/cogent-engine test:backend-ops:webgpu",
    "test:backend-ops:webgpu:op": "bun run --filter=@noumena-labs/cogent-engine test:backend-ops:webgpu:op",
    "test:backend-ops:webgpu:debug": "bun run --filter=@noumena-labs/cogent-engine test:backend-ops:webgpu:debug",
    "test:backend-ops:cuda": "bun run --filter=@noumena-labs/cogent-engine test:backend-ops:cuda",
    "test:backend-ops:cuda:op": "bun run --filter=@noumena-labs/cogent-engine test:backend-ops:cuda:op",
    "test:backend-ops:cuda:debug": "bun run --filter=@noumena-labs/cogent-engine test:backend-ops:cuda:debug",
    "bench:bun": "bun run --filter=@noumena-labs/cogent-engine bench:bun",
    "publish:cogent-engine": "bun ./scripts/publish-cogent-engine.mjs",
    "publish:cogent-engine:dry-run": "bun ./scripts/publish-cogent-engine.mjs --dry-run",
    "benchmark:dev": "bun run build:package && bun run --filter=cogent-engine-benchmark-app dev",
    "benchmark:build": "bun run build:package && bun run --filter=cogent-engine-benchmark-app build",
    "benchmark:preview": "bun run --filter=cogent-engine-benchmark-app preview",
    "avatar:dev": "bun run build:package && bun run --filter=cogent-engine-avatar-app dev",
    "avatar:build": "bun run build:package && bun run --filter=cogent-engine-avatar-app build",
    "avatar:preview": "bun run --filter=cogent-engine-avatar-app preview",
    "simulation:dev": "bun run build:package:dev && bun run --filter=cogent-engine-simulation-app dev",
    "simulation:build": "bun run build:package && bun run --filter=cogent-engine-simulation-app build",
    "simulation:preview": "bun run --filter=cogent-engine-simulation-app preview",
    "bench:browser": "bun ./scripts/benchmark-browser.mjs"
  },
  "devDependencies": {
    "playwright-core": "^1.54.2"
  }
}
