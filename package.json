{
  "name": "cogentlm-monorepo",
  "private": true,
  "version": "1.0.0",
  "packageManager": "bun@1.3.11",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "test": "bun test packages/*/src apps/*/src",
    "build": "bun run build:package",
    "build:package": "bun run --filter=@noumena-labs/cogentlm-browser build",
    "build:package:browser": "bun run --filter=@noumena-labs/cogentlm-browser build:browser",
    "build:package:release": "bun run --filter=@noumena-labs/cogentlm-browser build:release",
    "build:package:dev": "bun run --filter=@noumena-labs/cogentlm-browser build:dev",
    "rebuild:package": "bun run --filter=@noumena-labs/cogentlm-browser rebuild",
    "clean:package": "bun run --filter=@noumena-labs/cogentlm-browser clean",
    "build:wasm": "bun run --filter=@noumena-labs/cogentlm-browser build:wasm",
    "build:wasm:browser": "bun run --filter=@noumena-labs/cogentlm-browser build:wasm:browser",
    "build:wasm:browser:all": "bun run --filter=@noumena-labs/cogentlm-browser build:wasm:browser:all",
    "build:wasm:browser:pthread": "bun run --filter=@noumena-labs/cogentlm-browser build:wasm:browser:pthread",
    "build:wasm:dev": "bun run --filter=@noumena-labs/cogentlm-browser build:wasm:dev",
    "build:wasm:dev:all": "bun run --filter=@noumena-labs/cogentlm-browser build:wasm:dev:all",
    "build:wasm:dev:pthread": "bun run --filter=@noumena-labs/cogentlm-browser build:wasm:dev:pthread",
    "test:backend-ops:cpu": "bun run --filter=@noumena-labs/cogentlm-browser test:backend-ops:cpu",
    "test:backend-ops:cpu:op": "bun run --filter=@noumena-labs/cogentlm-browser test:backend-ops:cpu:op",
    "test:backend-ops:cpu:debug": "bun run --filter=@noumena-labs/cogentlm-browser test:backend-ops:cpu:debug",
    "test:backend-ops:webgpu": "bun run --filter=@noumena-labs/cogentlm-browser test:backend-ops:webgpu",
    "test:backend-ops:webgpu:op": "bun run --filter=@noumena-labs/cogentlm-browser test:backend-ops:webgpu:op",
    "test:backend-ops:webgpu:debug": "bun run --filter=@noumena-labs/cogentlm-browser test:backend-ops:webgpu:debug",
    "test:backend-ops:cuda": "bun run --filter=@noumena-labs/cogentlm-browser test:backend-ops:cuda",
    "test:backend-ops:cuda:op": "bun run --filter=@noumena-labs/cogentlm-browser test:backend-ops:cuda:op",
    "test:backend-ops:cuda:debug": "bun run --filter=@noumena-labs/cogentlm-browser test:backend-ops:cuda:debug",
    "benchmark:dev": "bun run build:package:browser && bun run --filter=cogentlm-browser-benchmark-app dev",
    "benchmark:browser:smoke": "bun run build:package:browser && bun run --filter=cogentlm-browser-benchmark-app browser:smoke:ingest",
    "benchmark:build": "bun run build:package:browser && bun run --filter=cogentlm-browser-benchmark-app build",
    "benchmark:preview": "bun run --filter=cogentlm-browser-benchmark-app preview",
    "avatar:dev": "bun run build:package && bun run --filter=cogentlm-browser-avatar-app dev",
    "avatar:build": "bun run build:package && bun run --filter=cogentlm-browser-avatar-app build",
    "avatar:preview": "bun run --filter=cogentlm-browser-avatar-app preview",
    "proactive-ui:dev": "bun run build:package && bun run --filter=cogentlm-browser-proactive-ui-app dev",
    "proactive-ui:build": "bun run build:package && bun run --filter=cogentlm-browser-proactive-ui-app build",
    "proactive-ui:preview": "bun run --filter=cogentlm-browser-proactive-ui-app preview",
    "simulation:dev": "bun run build:package:dev && bun run --filter=cogentlm-browser-simulation-app dev",
    "simulation:build": "bun run build:package && bun run --filter=cogentlm-browser-simulation-app build",
    "simulation:preview": "bun run --filter=cogentlm-browser-simulation-app preview",
    "examples:dev": "bun run build:package && bun run --filter=cogentlm-browser-examples dev",
    "examples:build": "bun run build:package && bun run --filter=cogentlm-browser-examples build",
    "examples:preview": "bun run --filter=cogentlm-browser-examples preview"
  },
  "devDependencies": {
    "playwright-core": "^1.54.2"
  }
}
