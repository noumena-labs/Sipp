{
  "name": "@noumena-labs/cogentlm-node",
  "version": "0.1.0",
  "private": true,
  "description": "Native Node.js bindings for CogentLM",
  "main": "router.js",
  "types": "router.d.ts",
  "license": "MIT",
  "files": [
    "index.d.ts",
    "index.js",
    "router.d.ts",
    "router.js"
  ],
  "scripts": {
    "build": "cargo xtask build node --backend all",
    "test": "node --test tests/router.test.mjs",
    "test:smoke": "node examples/node_smoke.mjs"
  },
  "napi": {
    "binaryName": "cogentlm_node",
    "targets": [
      "x86_64-apple-darwin",
      "aarch64-apple-darwin",
      "x86_64-pc-windows-msvc",
      "x86_64-unknown-linux-gnu"
    ]
  },
  "devDependencies": {
    "@napi-rs/cli": "^3.3.0",
    "c8": "^10.1.3"
  }
}
